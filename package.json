{
  "name": "murmur",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": "25.9.0"
  },
  "scripts": {
    "dev": "npm --prefix apps/desktop run dev --",
    "dev:desktop": "npm --prefix apps/desktop run dev --",
    "build": "npm --prefix apps/desktop run build --",
    "build:desktop": "npm --prefix apps/desktop run build --",
    "clean": "npm --prefix apps/desktop run clean --",
    "clean:all": "npm --prefix apps/desktop run clean:all --",
    "preview": "npm --prefix apps/desktop run preview --",
    "lint": "npm --prefix apps/desktop run lint --",
    "test": "npm run test:desktop && npm run test:scripts",
    "test:desktop": "npm --prefix apps/desktop run test --",
    "test:scripts": "vitest run scripts",
    "runtimes:prepare": "npm --prefix apps/desktop run runtimes:prepare --",
    "runtimes:package": "npm --prefix apps/desktop run runtimes:package --",
    "runtimes:stage": "npm --prefix apps/desktop run runtimes:stage --",
    "runtimes:doctor": "npm --prefix apps/desktop run runtimes:doctor --",
    "runtimes:manifest-check": "npm --prefix apps/desktop run runtimes:manifest-check --",
    "runtimes:manifest-check:release": "npm --prefix apps/desktop run runtimes:manifest-check:release --",
    "linux-helper:build": "npm --prefix apps/desktop run linux-helper:build --",
    "macos-helper:build": "npm --prefix apps/desktop run macos-helper:build --",
    "native-helpers:build": "npm --prefix apps/desktop run native-helpers:build --",
    "release:prepare": "npm --prefix apps/desktop run release:prepare --",
    "pack": "npm --prefix apps/desktop run pack --",
    "dist": "npm --prefix apps/desktop run dist --"
  }
}
