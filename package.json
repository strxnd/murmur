{
  "name": "murmur",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": "25.9.0"
  },
  "scripts": {
    "dev": "bun run dev:desktop",
    "dev:desktop": "bun run --cwd apps/desktop dev",
    "build": "bun run build:desktop",
    "build:desktop": "bun run --cwd apps/desktop build",
    "clean": "bun run --cwd apps/desktop clean",
    "clean:all": "bun run --cwd apps/desktop clean:all",
    "preview": "bun run preview:desktop",
    "preview:desktop": "bun run --cwd apps/desktop preview",
    "lint": "bun run lint:desktop",
    "lint:desktop": "bun run --cwd apps/desktop lint",
    "test": "bun run test:desktop && bun run test:scripts",
    "test:desktop": "bun run --cwd apps/desktop test",
    "test:scripts": "vitest run scripts",
    "runtimes:prepare": "bun run --cwd apps/desktop runtimes:prepare",
    "runtimes:package": "bun run --cwd apps/desktop runtimes:package",
    "runtimes:stage": "bun run --cwd apps/desktop runtimes:stage",
    "runtimes:doctor": "bun run --cwd apps/desktop runtimes:doctor",
    "runtimes:manifest-check": "bun run --cwd apps/desktop runtimes:manifest-check",
    "runtimes:manifest-check:release": "bun run --cwd apps/desktop runtimes:manifest-check:release",
    "linux-helper:build": "bun run --cwd apps/desktop linux-helper:build",
    "macos-helper:build": "bun run --cwd apps/desktop macos-helper:build",
    "native-helpers:build": "bun run --cwd apps/desktop native-helpers:build",
    "release:prepare": "bun run --cwd apps/desktop release:prepare",
    "pack": "bun run --cwd apps/desktop pack",
    "dist": "bun run --cwd apps/desktop dist",
    "dist:release": "bun run --cwd apps/desktop dist:release"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
